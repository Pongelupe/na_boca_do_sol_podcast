---
interface Props { name: string; slug: string; image?: string; }
const { name, slug, image } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a class="author-card" href={`${base}/${slug}/`} data-name={name.toLowerCase()}>
  {image && <div class="sun-portrait"><img src={image} alt={name} /></div>}
  <h3>{name}</h3>
</a>

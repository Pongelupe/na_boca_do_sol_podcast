---
import Base from '../layouts/Base.astro';
import SearchBar from '../components/SearchBar.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const authors = await getCollection('authors');
  return authors.map((author) => ({
    params: { slug: author.data.slug },
    props: { author },
  }));
}

const { author } = Astro.props;
const { Content } = await render(author);
const base = import.meta.env.BASE_URL;
---

<Base title={author.data.name}>
  <div class="author-header" data-base={base}>
    {author.data.image && <div class="sun-portrait sun-portrait--large"><img src={author.data.image} alt={author.data.name} /></div>}
    <h2>{author.data.name}</h2>
  </div>
  <div class="content">
    <Content />
  </div>

  <script>
    const table = document.querySelector('.content table');
    if (table) {
      const base = document.querySelector('.author-header')?.getAttribute('data-base') || '';
      // Build timeline from table
      const timeline = document.createElement('div');
      timeline.className = 'timeline';

      // Controls
      const controls = document.createElement('div');
      controls.className = 'table-controls';

      const input = document.createElement('input');
      input.type = 'text';
      input.className = 'search-bar';
      input.placeholder = 'Buscar texto...';

      const label = document.createElement('label');
      label.className = 'filter-toggle';
      const cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.checked = true;
      label.appendChild(cb);
      label.appendChild(document.createTextNode(' Apenas com episódio'));

      controls.appendChild(input);
      controls.appendChild(label);
      timeline.appendChild(controls);

      const rows = Array.from(table.querySelectorAll('tbody tr'));

      rows.forEach((row) => {
        const cells = row.querySelectorAll('td');
        const title = cells[0]?.textContent?.trim() || '';
        const year = cells[1]?.textContent?.trim() || '';
        const repoCell = cells[2];
        const miaCell = cells[3];

        const hasAudio = repoCell?.querySelector('audio') !== null;
        const hasBook = repoCell?.innerHTML.includes('📖');
        const miaLink = miaCell?.querySelector('a')?.getAttribute('href') || '';
        const bookLink = repoCell?.querySelector('a')?.getAttribute('href') || '';
        const audioEl = repoCell?.querySelector('audio');
        const audioSrc = audioEl?.getAttribute('src') || '';

        // Zip download for books
        const zipLink = hasBook
          ? Array.from(repoCell?.querySelectorAll('a') || []).find((a) => a.getAttribute('href')?.endsWith('.zip'))?.getAttribute('href') || ''
          : '';

        // Derive episode slug from audio URL: .../author/Episode_Slug.mp3
        let episodeUrl = '';
        if (hasAudio && audioSrc) {
          const parts = audioSrc.replace('.mp3', '').split('/');
          const epSlug = parts[parts.length - 1];
          const authorSlug = parts[parts.length - 3];
          episodeUrl = `${base}/${authorSlug}/${epSlug}/`;
        } else if (hasBook && bookLink) {
          episodeUrl = bookLink;
        }

        const item = document.createElement('div');
        item.className = 'timeline-item';
        item.dataset.text = title.toLowerCase() + ' ' + year.toLowerCase();
        item.dataset.hasEpisode = (hasAudio || hasBook) ? 'true' : 'false';

        // Year marker
        const yearEl = document.createElement('div');
        yearEl.className = 'timeline-year';
        yearEl.textContent = year;
        item.appendChild(yearEl);

        // Card — clickable if has episode
        let card: HTMLElement;
        if (episodeUrl) {
          const a = document.createElement('a');
          a.href = episodeUrl;
          a.className = 'timeline-card timeline-card--clickable';
          card = a;
        } else {
          card = document.createElement('div');
          card.className = 'timeline-card';
        }

        // Title row
        const titleRow = document.createElement('div');
        titleRow.className = 'timeline-title';

        if (hasAudio) {
          const badge = document.createElement('span');
          badge.className = 'badge badge--audio';
          badge.textContent = '♫';
          badge.title = 'Episódio disponível';
          titleRow.appendChild(badge);
        } else if (hasBook) {
          const badge = document.createElement('span');
          badge.className = 'badge badge--book';
          badge.textContent = '📖';
          badge.title = 'Ver capítulos';
          titleRow.appendChild(badge);
        }

        const titleSpan = document.createElement('span');
        titleSpan.textContent = title;
        titleRow.appendChild(titleSpan);

        // MIA link as visible icon
        if (miaLink) {
          const mia = document.createElement('a');
          mia.href = miaLink;
          mia.target = '_blank';
          mia.className = 'mia-link';
          mia.title = 'Ler no Marxists.org';
          mia.textContent = '🔗';
          mia.addEventListener('click', (e) => e.stopPropagation());
          titleRow.appendChild(mia);
        }

        // Download icon for audio episodes
        if (hasAudio && audioSrc) {
          const dl = document.createElement('a');
          dl.href = audioSrc;
          dl.className = 'timeline-download';
          dl.title = 'Baixar episódio';
          dl.textContent = '⬇️';
          dl.setAttribute('download', '');
          dl.addEventListener('click', (e) => e.stopPropagation());
          titleRow.appendChild(dl);
        }

        // Download zip for books
        if (hasBook && zipLink) {
          const dl = document.createElement('a');
          dl.href = zipLink;
          dl.className = 'timeline-download';
          dl.title = 'Baixar livro completo (zip)';
          dl.textContent = '⬇️';
          dl.setAttribute('download', '');
          dl.addEventListener('click', (e) => e.stopPropagation());
          titleRow.appendChild(dl);
        }

        card.appendChild(titleRow);

        item.appendChild(card);
        timeline.appendChild(item);
      });

      table.replaceWith(timeline);

      // Filter logic
      function filter() {
        const q = input.value.toLowerCase();
        const audioOnly = cb.checked;
        timeline.querySelectorAll('.timeline-item').forEach((item) => {
          const el = item as HTMLElement;
          const matchesSearch = el.dataset.text!.includes(q);
          const hasEp = el.dataset.hasEpisode === 'true';
          el.style.display = matchesSearch && (!audioOnly || hasEp) ? '' : 'none';
        });
      }

      input.addEventListener('input', filter);
      cb.addEventListener('change', filter);
      filter();
    }
  </script>
</Base>
